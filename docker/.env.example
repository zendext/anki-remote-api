# Copy to .env and fill in values.

# AnkiWeb sync token — obtain via: go run ./cmd/ankiauth
ANKI_SYNC_HKEY=your_hkey_here

# Bearer token that callers must send to anki-remote-api
API_TOKEN=change_me

# DB connection — sqlite or postgres
DATABASE_URL=sqlite:///data/app.db
# DATABASE_URL=postgres://user:pass@host:5432/ankiremote

# Host port for anki-remote-api
LISTEN_PORT=8080
